# Frontend Environment Configuration
NODE_ENV=development

# API Configuration
API_URL=http://localhost:3000

# Application Configuration
APP_NAME=Fintrax
APP_VERSION=1.0.0

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_DEBUG=true

# Security
CORS_ORIGIN=http://localhost:4200

# Cache Configuration
CACHE_TTL=300000

# Logging
LOG_LEVEL=info
